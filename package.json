{
  "name": "groweasy-ai-csv-importer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter @groweasy/shared build && pnpm --parallel --filter @groweasy/web --filter @groweasy/api dev",
    "dev:web": "pnpm --filter @groweasy/shared build && pnpm --filter @groweasy/web dev",
    "dev:api": "pnpm --filter @groweasy/shared build && pnpm --filter @groweasy/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
