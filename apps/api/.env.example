NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
JSON_BODY_LIMIT=1mb
LOG_REQUESTS=true
MAX_CSV_FILE_SIZE_BYTES=5242880

# Use mock for local demos and tests. Use gemini for a real Gemini API call.
# openai and claude are reserved placeholders.
AI_PROVIDER=mock
AI_BATCH_SIZE=25
AI_BATCH_RETRY_LIMIT=1
AI_REQUEST_TIMEOUT_MS=30000

# Backend-only secret. Never prefix secrets with NEXT_PUBLIC_.
# Leave empty for AI_PROVIDER=mock. For AI_PROVIDER=gemini, set AI_API_KEY or GEMINI_API_KEY.
AI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
