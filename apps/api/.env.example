NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
JSON_BODY_LIMIT=1mb
LOG_REQUESTS=true
MAX_CSV_FILE_SIZE_BYTES=5242880

# Use mock for local demos and tests. Supported placeholders: mock, openai, gemini, claude.
AI_PROVIDER=mock
AI_BATCH_SIZE=25
AI_BATCH_RETRY_LIMIT=1

# Backend-only secret. Never prefix secrets with NEXT_PUBLIC_.
# Leave empty for AI_PROVIDER=mock.
AI_API_KEY=
